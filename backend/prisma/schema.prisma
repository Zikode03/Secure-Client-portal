generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String          @id
  fullName         String
  email            String          @unique
  passwordHash     String
  role             String
  clientIds        Json
  profile          Json?
  security         Json?
  createdAt        DateTime        @default(now())
  sessions         Session[]
  loginActivities  LoginActivity[]
  notifications    Notification[]
  auditsAsActor    Audit[]         @relation("AuditActor")
  tasksCreated     Task[]          @relation("TaskCreator")
  requestsCreated  Request[]       @relation("RequestCreator")
  documentsUploaded Document[]     @relation("DocumentUploader")
}

model Session {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Client {
  id                 String      @id
  name               String
  entityType         String
  status             String
  complianceHealth   Int
  assignedAccountantId String
  primaryContact     String
  email              String
  createdAt          DateTime    @default(now())
  documents          Document[]
  tasks              Task[]
  requests           Request[]
  messages           Message[]
  complianceAccounts ComplianceAccount[]
  complianceObligations ComplianceObligation[]
  complianceSnapshots ComplianceStatusSnapshot[]
  complianceEvents   ComplianceEvent[]
  complianceAlerts   ComplianceAlert[]
  complianceAuditLogs ComplianceAuditLog[]
}

model Message {
  id            String   @id
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fromUserId    String
  toRole        String
  body          String
  deliveryStatus String
  readBy        Json
  createdAt     DateTime @default(now())
}

model Request {
  id                String   @id
  clientId          String
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title             String
  description       String
  priority          String
  status            String
  dueDate           DateTime?
  requestedByUserId String
  requestedBy       User     @relation("RequestCreator", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  requestedAt       DateTime @default(now())
  history           Json
}

model Task {
  id         String   @id
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title      String
  status     String
  dueDate    DateTime?
  priority   String
  createdBy  String
  creator    User     @relation("TaskCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt  DateTime @default(now())
}

model Document {
  id          String   @id
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  category    String
  status      String
  sizeBytes   Int
  key         String?
  uploadedBy  String
  uploader    User     @relation("DocumentUploader", fields: [uploadedBy], references: [id], onDelete: Restrict)
  uploadedAt  DateTime @default(now())
}

model Notification {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LoginActivity {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  device    String
  location  String
  ipAddress String
  createdAt DateTime @default(now())
}

model Audit {
  id          String   @id
  actorUserId String?
  actor       User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())
}

model ComplianceAccount {
  id               String   @id
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  source           String
  reference        String
  status           String
  lastSyncedAt     DateTime?
  lastError        String?
  credentialsMeta  Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([clientId, source])
}

model ComplianceObligation {
  id             String   @id
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  source         String
  obligationType String
  periodLabel    String?
  dueDate        DateTime?
  submittedAt    DateTime?
  paidAt         DateTime?
  status         String
  amountDue      Float?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([clientId, source, obligationType])
  @@index([clientId, status])
}

model ComplianceStatusSnapshot {
  id               String   @id
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  overallStatus    String
  score            Int
  sarsStatus       String
  cipcStatus       String
  compliantCount   Int
  nonCompliantCount Int
  overdueCount     Int
  dueSoonCount     Int
  sourceTimestamp  DateTime
  createdAt        DateTime @default(now())

  @@index([clientId, createdAt(sort: Desc)])
}

model ComplianceEvent {
  id            String   @id
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  source        String
  eventType     String
  severity      String
  title         String
  description   String
  obligationRef String?
  payload       Json?
  occurredAt    DateTime
  createdAt     DateTime @default(now())

  @@index([clientId, occurredAt(sort: Desc)])
}

model ComplianceAlert {
  id               String   @id
  clientId         String
  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  severity         String
  status           String
  title            String
  message          String
  source           String
  obligationType   String?
  assignedUserId   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  resolvedAt       DateTime?
  readAt           DateTime?

  @@index([clientId, status, createdAt(sort: Desc)])
}

model ComplianceAuditLog {
  id           String   @id
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  actorUserId  String?
  action       String
  details      Json?
  createdAt    DateTime @default(now())

  @@index([clientId, createdAt(sort: Desc)])
}
